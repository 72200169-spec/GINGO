<Window x:Class="GinGo.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:oxy="http://oxyplot.org/wpf"
        mc:Ignorable="d"
        Title="GinGo - Dashboard" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BgBrush}"
        Foreground="{DynamicResource FgBrush}">
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{DynamicResource SidebarBgBrush}" BorderBrush="#20000000" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="20,30,20,20">
                    <TextBlock Text="GinGo" FontSize="32" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" />
                    <TextBlock Text="Admin" FontSize="14" Foreground="{DynamicResource SidebarFgBrush}" Margin="0,5,0,0" Opacity="0.8" />
                    <TextBlock x:Name="RucTextBlock" Text="RUC: 12345678901" FontSize="12" Foreground="{DynamicResource SidebarFgBrush}" Margin="0,2,0,0" Opacity="0.6" />
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="10,20">
                    <Button x:Name="BtnDashboard" Content="Dashboard" Margin="0,5" Height="45" Background="Transparent" Foreground="{DynamicResource SidebarFgBrush}" Click="Menu_Click" Tag="DashboardView" HorizontalContentAlignment="Left" Padding="20,0"/>
                    <Button x:Name="BtnValidarUsuario" Content="Validar Usuario" Margin="0,5" Height="45" Background="Transparent" Foreground="{DynamicResource SidebarFgBrush}" Click="Menu_Click" Tag="ValidarUsuarioView" HorizontalContentAlignment="Left" Padding="20,0"/>
                    <Button x:Name="BtnGenerarIngreso" Content="Generar Ingreso" Margin="0,5" Height="45" Background="Transparent" Foreground="{DynamicResource SidebarFgBrush}" Click="Menu_Click" Tag="GenerarIngresoView" HorizontalContentAlignment="Left" Padding="20,0" Visibility="Collapsed"/>
                    <Button x:Name="BtnHistorial" Content="Historial Facturas" Margin="0,5" Height="45" Background="Transparent" Foreground="{DynamicResource SidebarFgBrush}" Click="Menu_Click" Tag="HistorialView" HorizontalContentAlignment="Left" Padding="20,0" Visibility="Collapsed"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Margin="20,20">
                    <Button Content="Cambiar Tema" Margin="0,0,0,10" Height="40" Background="{DynamicResource CardBgBrush}" Foreground="{DynamicResource FgBrush}" Click="ThemeToggle_Click" />
                    <Button Content="Cerrar Sesión" Height="40" Background="#EF4444" Foreground="White" Click="Logout_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Column="1" Margin="20">
            <!-- View: Dashboard -->
            <Grid x:Name="DashboardView" Visibility="Visible">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                    <Grid MinWidth="800">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" Text="Resumen de Emisiones" FontSize="28" FontWeight="SemiBold" Margin="0,10,0,20" />
                        
                        <!-- Cards -->
                        <Grid Grid.Row="1" Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            
                            <Border Grid.Column="0" Background="{DynamicResource CardBgBrush}" CornerRadius="10" Padding="20" Margin="0,0,10,0" Effect="{DynamicResource CardShadow}">
                                <StackPanel>
                                    <TextBlock Text="Facturas Hoy" FontSize="14" Opacity="0.7" />
                                    <TextBlock Text="12" FontSize="28" FontWeight="Bold" Margin="0,5,0,0" Foreground="{DynamicResource AccentBrush}" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Background="{DynamicResource CardBgBrush}" CornerRadius="10" Padding="20" Margin="10,0,10,0" Effect="{DynamicResource CardShadow}">
                                <StackPanel>
                                    <TextBlock Text="Este Mes" FontSize="14" Opacity="0.7" />
                                    <TextBlock Text="145" FontSize="28" FontWeight="Bold" Margin="0,5,0,0" Foreground="{DynamicResource AccentBrush}" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Background="{DynamicResource CardBgBrush}" CornerRadius="10" Padding="20" Margin="10,0,0,0" Effect="{DynamicResource CardShadow}">
                                <StackPanel>
                                    <TextBlock Text="Total Año" FontSize="14" Opacity="0.7" />
                                    <TextBlock Text="1,204" FontSize="28" FontWeight="Bold" Margin="0,5,0,0" Foreground="{DynamicResource AccentBrush}" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Charts -->
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="300" />
                                <RowDefinition Height="300" />
                            </Grid.RowDefinitions>

                            <Border Grid.Column="0" Grid.Row="0" Background="{DynamicResource CardBgBrush}" CornerRadius="10" Margin="0,0,10,10" Padding="15">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Emisiones por Día (Última Semana)" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                    <oxy:PlotView Grid.Row="1" Model="{Binding DailyModel}" Background="Transparent" />
                                </Grid>
                            </Border>

                            <Border Grid.Column="0" Grid.Row="1" Background="{DynamicResource CardBgBrush}" CornerRadius="10" Margin="0,10,10,0" Padding="15">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Emisiones por Mes (Año Actual)" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                    <oxy:PlotView Grid.Row="1" Model="{Binding MonthlyModel}" Background="Transparent" />
                                </Grid>
                            </Border>

                            <Border Grid.Column="1" Grid.Row="0" Grid.RowSpan="2" Background="{DynamicResource CardBgBrush}" CornerRadius="10" Margin="10,0,0,0" Padding="15">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Tipos de Comprobante" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                    <oxy:PlotView Grid.Row="1" Model="{Binding TypeModel}" Background="Transparent" />
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </ScrollViewer>
            </Grid>

            <!-- View: Validar Usuario -->
            <Grid x:Name="ValidarUsuarioView" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Validar Usuario SUNAT" FontSize="28" FontWeight="SemiBold" Margin="0,10,0,20" />
                
                <Border Grid.Row="1" Background="{DynamicResource CardBgBrush}" CornerRadius="10" Padding="30" VerticalAlignment="Top" HorizontalAlignment="Left" Width="400">
                    <StackPanel>
                        <TextBlock Text="Ingresa tus credenciales SOL" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,5" />
                        <TextBlock Text="Para habilitar la generación de comprobantes" Opacity="0.7" Margin="0,0,0,20" />
                        
                        <TextBlock Text="Datos de prueba: Usuario SOL: ADMINSOL | Pass: Sol123! | El RUC se valida en línea" FontSize="11" Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,15" TextWrapping="Wrap" />

                        <TextBlock Text="RUC" Opacity="0.8" Margin="0,0,0,5" />
                        <TextBox x:Name="ValidarRucTextBox" Height="38" Padding="10,0" VerticalContentAlignment="Center" Background="{DynamicResource BgBrush}" Foreground="{DynamicResource FgBrush}" BorderBrush="#40888888" Margin="0,0,0,15" />

                        <TextBlock Text="Usuario SOL" Opacity="0.8" Margin="0,0,0,5" />
                        <TextBox x:Name="ValidarUsuarioSolTextBox" Height="38" Padding="10,0" VerticalContentAlignment="Center" Background="{DynamicResource BgBrush}" Foreground="{DynamicResource FgBrush}" BorderBrush="#40888888" Margin="0,0,0,15" />

                        <TextBlock Text="Contraseña SOL" Opacity="0.8" Margin="0,0,0,5" />
                        <PasswordBox x:Name="ValidarPassSolBox" Height="38" Padding="10,0" VerticalContentAlignment="Center" Background="{DynamicResource BgBrush}" Foreground="{DynamicResource FgBrush}" BorderBrush="#40888888" Margin="0,0,0,25" />

                        <Button Content="Validar Credenciales" Height="40" Background="{DynamicResource AccentBrush}" Foreground="White" FontWeight="SemiBold" Click="ValidarSunat_Click" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- View: Generar Ingreso -->
            <Grid x:Name="GenerarIngresoView" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Generar Ingreso" FontSize="28" FontWeight="SemiBold" Margin="0,10,0,20" />
                
                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                        <Button Content="Generar Factura" Width="150" Height="40" Background="{DynamicResource AccentBrush}" Foreground="White" FontWeight="SemiBold" Margin="0,0,15,0" Click="ShowFacturaForm_Click"/>
                        <Button Content="Generar Boleta" Width="150" Height="40" Background="{DynamicResource AccentBrush}" Foreground="White" FontWeight="SemiBold" Margin="0,0,15,0" Click="ShowBoletaForm_Click"/>
                        <Button Content="Cambiar Credenciales SUNAT" Width="200" Height="40" Background="Transparent" Foreground="{DynamicResource FgBrush}" BorderBrush="#40888888" BorderThickness="1" Click="BackToSunatValidation_Click"/>
                    </StackPanel>

                    <!-- Contenedor para el formulario de Factura -->
                    <Grid Grid.Row="1" x:Name="FacturaFormContainer" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                            <Border Background="{DynamicResource CardBgBrush}" CornerRadius="10" Padding="20" Margin="0,0,10,20" MinWidth="800">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Sección 1: Datos de la Factura -->
                                    <TextBlock Text="Datos de la Factura" FontWeight="SemiBold" FontSize="16" Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,10"/>
                                    <Grid Grid.Row="1" Margin="0,0,0,20">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        
                                        <!-- Fila 1 -->
                                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,15">
                                            <TextBlock Text="Tipo Comprobante" Opacity="0.8" Margin="0,0,0,5"/>
                                            <TextBox Text="FACTURA (01)" IsReadOnly="True" Height="30" Padding="5" Background="{DynamicResource SidebarBgBrush}" Foreground="{DynamicResource FgBrush}" BorderBrush="#40888888"/>
                                        </StackPanel>
                                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="10,0,10,15">
                                            <TextBlock Text="Serie" Opacity="0.8" Margin="0,0,0,5"/>
                                            <TextBox Text="F001" Height="30" Padding="5" Background="{DynamicResource BgBrush}" Foreground="{DynamicResource FgBrush}" BorderBrush="#40888888"/>
                                        </StackPanel>
                                        <StackPanel Grid.Row="0" Grid.Column="2" Margin="10,0,10,15">
                                            <TextBlock Text="Número" Opacity="0.8" Margin="0,0,0,5"/>
                                            <TextBox Text="(Auto generado)" IsReadOnly="True" Height="30" Padding="5" Background="{DynamicResource SidebarBgBrush}" Foreground="{DynamicResource FgBrush}" BorderBrush="#40888888"/>
                                        </StackPanel>
                                        <StackPanel Grid.Row="0" Grid.Column="3" Margin="10,0,0,15">
                                            <TextBlock Text="Moneda" Opacity="0.8" Margin="0,0,0,5"/>
                                            <ComboBox Height="30" SelectedIndex="0" Background="{DynamicResource InputBgBrush}" Foreground="{DynamicResource FgBrush}" BorderBrush="#40888888">
                                                <ComboBoxItem Content="PEN - Soles" Foreground="Black"/>
                                                <ComboBoxItem Content="USD - Dólares" Foreground="Black"/>
                                            </ComboBox>
                                        </StackPanel>

                                        <!-- Fila 2 -->
                                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,0">
                                            <TextBlock Text="Fecha Emisión" Opacity="0.8" Margin="0,0,0,5"/>
                                            <DatePicker SelectedDate="{x:Static sys:DateTime.Now}" Height="30" Background="{DynamicResource InputBgBrush}" Foreground="{DynamicResource FgBrush}" BorderBrush="#40888888" xmlns:sys="clr-namespace:System;assembly=mscorlib" />
                                        </StackPanel>
                                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="10,0,10,0">
                                            <TextBlock Text="Fecha Vencimiento" Opacity="0.8" Margin="0,0,0,5"/>
                                            <DatePicker Height="30" Background="{DynamicResource InputBgBrush}" Foreground="{DynamicResource FgBrush}" BorderBrush="#40888888" />
                                        </StackPanel>
                                    </Grid>

                                    <!-- Sección 2: Datos del Cliente -->
                                    <TextBlock Grid.Row="2" Text="Datos del Cliente (Obligatorio Completo)" FontWeight="SemiBold" FontSize="16" Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,10"/>
                                    <Grid Grid.Row="3" Margin="0,0,0,20">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="2*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        
                                        <!-- Fila 1 -->
                                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,15">
                                            <TextBlock Text="Tipo Documento" Opacity="0.8" Margin="0,0,0,5"/>
                                            <ComboBox Height="30" SelectedIndex="0" Background="{DynamicResource InputBgBrush}" Foreground="{DynamicResource FgBrush}" BorderBrush="#40888888">
                                                <ComboBoxItem Content="RUC" Foreground="Black"/>
                                            </ComboBox>
                                        </StackPanel>
                                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="10,0,10,15">
                                            <TextBlock Text="Número" Opacity="0.8" Margin="0,0,0,5"/>
                                            <TextBox x:Name="FacturaDocNumeroTextBox" Text="20000000001" LostFocus="FacturaDocNumero_LostFocus" Height="30" Padding="5" Background="{DynamicResource BgBrush}" Foreground="{DynamicResource FgBrush}" BorderBrush="#40888888"/>
                                        </StackPanel>
                                        <StackPanel Grid.Row="0" Grid.Column="2" Margin="10,0,10,15">
                                            <TextBlock Text="Razón Social" Opacity="0.8" Margin="0,0,0,5"/>
                                            <TextBox x:Name="FacturaRazonSocialTextBox" Text="" Height="30" Padding="5" Background="{DynamicResource BgBrush}" Foreground="{DynamicResource FgBrush}" BorderBrush="#40888888"/>
                                        </StackPanel>
                                        <StackPanel Grid.Row="0" Grid.Column="3" Margin="10,0,0,15">
                                            <TextBlock Text="Dirección" Opacity="0.8" Margin="0,0,0,5"/>
                                            <TextBox x:Name="FacturaDireccionTextBox" Text="" Height="30" Padding="5" Background="{DynamicResource BgBrush}" Foreground="{DynamicResource FgBrush}" BorderBrush="#40888888"/>
                                        </StackPanel>

                                        <!-- Fila 2 -->
                                        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,10,0">
                                            <TextBlock Text="Teléfono" Opacity="0.8" Margin="0,0,0,5"/>
                                            <TextBox Text="" Height="30" Padding="5" Background="{DynamicResource BgBrush}" Foreground="{DynamicResource FgBrush}" BorderBrush="#40888888"/>
                                        </StackPanel>
                                        <StackPanel Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2" Margin="10,0,0,0">
                                            <TextBlock Text="Correo Electrónico" Opacity="0.8" Margin="0,0,0,5"/>
                                            <TextBox Text="" Height="30" Padding="5" Background="{DynamicResource BgBrush}" Foreground="{DynamicResource FgBrush}" BorderBrush="#40888888"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Sección 2.5: Forma de Pago -->
                                    <TextBlock Grid.Row="4" Text="Forma de Pago" FontWeight="SemiBold" FontSize="16" Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,10"/>
                                    <Grid Grid.Row="5" Margin="0,0,0,20">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="2*"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                            <TextBlock Text="Tipo" Opacity="0.8" Margin="0,0,0,5"/>
                                            <ComboBox Height="30" SelectedIndex="0" Background="{DynamicResource InputBgBrush}" Foreground="{DynamicResource FgBrush}" BorderBrush="#40888888">
                                                <ComboBoxItem Content="Contado" Foreground="Black"/>
                                                <ComboBoxItem Content="Crédito" Foreground="Black"/>
                                            </ComboBox>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="10,0,10,0">
                                            <TextBlock Text="Cuotas (si es crédito)" Opacity="0.8" Margin="0,0,0,5"/>
                                            <TextBox Text="0" Height="30" Padding="5" Background="{DynamicResource BgBrush}" Foreground="{DynamicResource FgBrush}" BorderBrush="#40888888"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Sección 3: Detalle del Servicio/Producto -->
                                    <TextBlock Grid.Row="6" Text="Detalle de Facturación" FontWeight="SemiBold" FontSize="16" Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,10"/>
                                    <StackPanel Grid.Row="7" Margin="0,0,0,10">
                                        <Button Content="+ Añadir detalle" Width="150" Height="38" HorizontalAlignment="Left" Margin="0,0,0,15" Background="{DynamicResource AccentBrush}" Foreground="White" FontWeight="SemiBold" Click="AgregarDetalleFactura_Click"/>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="0.8*"/>
                                                <ColumnDefinition Width="3*"/>
                                                <ColumnDefinition Width="0.8*"/>
                                                <ColumnDefinition Width="0.8*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="1.2*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Código" FontWeight="SemiBold" Margin="0,0,5,5"/>
                                            <TextBlock Grid.Column="1" Text="Descripción" FontWeight="SemiBold" Margin="5,0,5,5"/>
                                            <TextBlock Grid.Column="2" Text="Unidad" FontWeight="SemiBold" Margin="5,0,5,5"/>
                                            <TextBlock Grid.Column="3" Text="Cant." FontWeight="SemiBold" Margin="5,0,5,5"/>
                                            <TextBlock Grid.Column="4" Text="Precio Total" FontWeight="SemiBold" Margin="5,0,5,5"/>
                                            <TextBlock Grid.Column="5" Text="Tipo IGV" FontWeight="SemiBold" Margin="5,0,0,5"/>
                                        </Grid>
                                        <ItemsControl ItemsSource="{Binding FacturaDetalles}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,0,0,12">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="0.8*"/>
                                                            <ColumnDefinition Width="3*"/>
                                                            <ColumnDefinition Width="0.8*"/>
                                                            <ColumnDefinition Width="0.8*"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="1.2*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBox Grid.Column="0" Text="{Binding Codigo, UpdateSourceTrigger=PropertyChanged}" Height="35" Padding="5" VerticalContentAlignment="Center" Background="{DynamicResource BgBrush}" Foreground="{DynamicResource FgBrush}" BorderBrush="#40888888" Margin="0,0,5,0"/>
                                                        <TextBox Grid.Column="1" Text="{Binding Descripcion, UpdateSourceTrigger=PropertyChanged}" Height="35" Padding="5" VerticalContentAlignment="Center" Background="{DynamicResource BgBrush}" Foreground="{DynamicResource FgBrush}" BorderBrush="#40888888" Margin="5,0,5,0"/>
                                                        <TextBox Grid.Column="2" Text="{Binding Unidad, UpdateSourceTrigger=PropertyChanged}" Height="35" Padding="5" VerticalContentAlignment="Center" Background="{DynamicResource BgBrush}" Foreground="{DynamicResource FgBrush}" BorderBrush="#40888888" Margin="5,0,5,0"/>
                                                        <TextBox Grid.Column="3" Text="{Binding Cantidad, UpdateSourceTrigger=PropertyChanged}" Height="35" Padding="5" VerticalContentAlignment="Center" Background="{DynamicResource BgBrush}" Foreground="{DynamicResource FgBrush}" BorderBrush="#40888888" Margin="5,0,5,0"/>
                                                        <TextBox Grid.Column="4" Text="{Binding PrecioTotal, UpdateSourceTrigger=PropertyChanged}" Height="35" Padding="5" VerticalContentAlignment="Center" Background="{DynamicResource BgBrush}" Foreground="{DynamicResource FgBrush}" BorderBrush="#40888888" Margin="5,0,5,0"/>
                                                        <ComboBox Grid.Column="5" Height="35" VerticalContentAlignment="Center" ItemsSource="{Binding DataContext.TipoIgvOptions, RelativeSource={RelativeSource AncestorType=Window}}" SelectedItem="{Binding TipoIgv, UpdateSourceTrigger=PropertyChanged}" Background="{DynamicResource InputBgBrush}" Foreground="{DynamicResource FgBrush}" BorderBrush="#40888888" Margin="5,0,0,0"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>

                                    <Grid Grid.Row="8" Margin="0,90,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" MinWidth="300" />
                                        </Grid.ColumnDefinitions>
                                        
                                        <StackPanel Grid.Column="1" HorizontalAlignment="Right" MinWidth="250" Margin="0,0,20,0">
                                            <Grid Margin="0,5">
                                                <TextBlock Text="Subtotal:" HorizontalAlignment="Left" FontSize="14"/>
                                                <TextBlock Text="{Binding FacturaSubtotalTexto}" HorizontalAlignment="Right" FontWeight="SemiBold" FontSize="14"/>
                                            </Grid>
                                            <Grid Margin="0,5">
                                                <TextBlock Text="IGV (18%):" HorizontalAlignment="Left" FontSize="14"/>
                                                <TextBlock Text="{Binding FacturaIgvTexto}" HorizontalAlignment="Right" FontWeight="SemiBold" FontSize="14"/>
                                            </Grid>
                                            <Border BorderBrush="#40888888" BorderThickness="0,1,0,0" Margin="0,10"/>
                                            <Grid Margin="0,5">
                                                <TextBlock Text="Total:" HorizontalAlignment="Left" FontSize="18" FontWeight="Bold"/>
                                                <TextBlock Text="{Binding FacturaTotalTexto}" HorizontalAlignment="Right" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"/>
                                            </Grid>
                                        </StackPanel>
                                    </Grid>

                                    <StackPanel Grid.Row="9" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,90,0,30">
                                        <Button Content="Limpiar" MinWidth="150" Height="45" Background="Transparent" Foreground="{DynamicResource FgBrush}" BorderBrush="#40888888" BorderThickness="1" Margin="0,0,20,0" FontSize="14" Padding="20,0" Click="LimpiarFactura_Click"/>
                                        <Button Content="Generar y Enviar a SUNAT" MinWidth="250" Height="45" Background="{DynamicResource AccentBrush}" Foreground="White" FontWeight="SemiBold" FontSize="14" Padding="20,0" Click="EmitirFactura_Click"/>
                                    </StackPanel>

                                </Grid>
                            </Border>
                        </ScrollViewer>
                    </Grid>

                    <!-- Contenedor para el formulario de Boleta -->
                    <Grid Grid.Row="1" x:Name="BoletaFormContainer" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                            <Border Background="{DynamicResource CardBgBrush}" CornerRadius="10" Padding="20" Margin="0,0,10,20" MinWidth="800">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Sección 1: Datos de la Boleta -->
                                    <TextBlock Text="Datos de la Boleta" FontWeight="SemiBold" FontSize="16" Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,10"/>
                                    <Grid Grid.Row="1" Margin="0,0,0,20">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        
                                        <!-- Fila 1 -->
                                        <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,10,15">
                                            <TextBlock Text="Tipo Comprobante" Opacity="0.8" Margin="0,0,0,5"/>
                                            <TextBox Text="BOLETA (03)" IsReadOnly="True" Height="30" Padding="5" Background="{DynamicResource SidebarBgBrush}" Foreground="{DynamicResource FgBrush}" BorderBrush="#40888888"/>
                                        </StackPanel>
                                        <StackPanel Grid.Row="0" Grid.Column="2" Margin="10,0,10,15">
                                            <TextBlock Text="Serie" Opacity="0.8" Margin="0,0,0,5"/>
                                            <TextBox Text="B001" Height="30" Padding="5" Background="{DynamicResource BgBrush}" Foreground="{DynamicResource FgBrush}" BorderBrush="#40888888"/>
                                        </StackPanel>
                                        <StackPanel Grid.Row="0" Grid.Column="3" Margin="10,0,0,15">
                                            <TextBlock Text="Número" Opacity="0.8" Margin="0,0,0,5"/>
                                            <TextBox Text="(Auto generado)" IsReadOnly="True" Height="30" Padding="5" Background="{DynamicResource SidebarBgBrush}" Foreground="{DynamicResource FgBrush}" BorderBrush="#40888888"/>
                                        </StackPanel>

                                        <!-- Fila 2 -->
                                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,0">
                                            <TextBlock Text="Fecha Emisión" Opacity="0.8" Margin="0,0,0,5"/>
                                            <DatePicker SelectedDate="{x:Static sys:DateTime.Now}" Height="30" Background="{DynamicResource InputBgBrush}" Foreground="{DynamicResource FgBrush}" BorderBrush="#40888888" xmlns:sys="clr-namespace:System;assembly=mscorlib" />
                                        </StackPanel>
                                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="10,0,10,0">
                                            <TextBlock Text="Moneda" Opacity="0.8" Margin="0,0,0,5"/>
                                            <ComboBox Height="30" SelectedIndex="0" Background="{DynamicResource InputBgBrush}" Foreground="{DynamicResource FgBrush}" BorderBrush="#40888888">
                                                <ComboBoxItem Content="PEN - Soles" Foreground="Black"/>
                                                <ComboBoxItem Content="USD - Dólares" Foreground="Black"/>
                                            </ComboBox>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Sección 2: Datos del Cliente (Simplificado) -->
                                    <TextBlock Grid.Row="2" Text="Datos del Cliente (Simplificado)" FontWeight="SemiBold" FontSize="16" Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,10"/>
                                    <Grid Grid.Row="3" Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="2*"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                            <TextBlock Text="Tipo Documento" Opacity="0.8" Margin="0,0,0,5"/>
                                            <ComboBox x:Name="BoletaTipoDocComboBox" Height="30" SelectedIndex="0" Background="{DynamicResource InputBgBrush}" Foreground="{DynamicResource FgBrush}" BorderBrush="#40888888">
                                                <ComboBoxItem Content="DNI" Foreground="Black"/>
                                                <ComboBoxItem Content="SIN DOC" Foreground="Black"/>
                                                <ComboBoxItem Content="RUC" Foreground="Black"/>
                                            </ComboBox>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="10,0,10,0">
                                            <TextBlock Text="Número" Opacity="0.8" Margin="0,0,0,5"/>
                                            <TextBox x:Name="BoletaDocNumeroTextBox" Text="20203030" LostFocus="BoletaDocNumero_LostFocus" Height="30" Padding="5" Background="{DynamicResource BgBrush}" Foreground="{DynamicResource FgBrush}" BorderBrush="#40888888"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Margin="10,0,0,0">
                                            <TextBlock Text="Nombre (Persona)" Opacity="0.8" Margin="0,0,0,5"/>
                                            <TextBox x:Name="BoletaNombreTextBox" Text="Juan Perez" Height="30" Padding="5" Background="{DynamicResource BgBrush}" Foreground="{DynamicResource FgBrush}" BorderBrush="#40888888"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Campos Opcionales (No obligatorios) -->
                                    <TextBlock Grid.Row="4" Text="Campos Opcionales" FontWeight="SemiBold" FontSize="14" Foreground="{DynamicResource FgBrush}" Opacity="0.7" Margin="0,0,0,10"/>
                                    <Grid Grid.Row="5" Margin="0,0,0,20">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                            <TextBlock Text="Dirección" Opacity="0.6" Margin="0,0,0,5"/>
                                            <TextBox x:Name="BoletaDireccionTextBox" Text="" Height="30" Padding="5" Background="{DynamicResource BgBrush}" Foreground="{DynamicResource FgBrush}" BorderBrush="#40888888"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="10,0,10,0">
                                            <TextBlock Text="Teléfono" Opacity="0.6" Margin="0,0,0,5"/>
                                            <TextBox Text="" Height="30" Padding="5" Background="{DynamicResource BgBrush}" Foreground="{DynamicResource FgBrush}" BorderBrush="#40888888"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Margin="10,0,0,0">
                                            <TextBlock Text="Correo" Opacity="0.6" Margin="0,0,0,5"/>
                                            <TextBox Text="" Height="30" Padding="5" Background="{DynamicResource BgBrush}" Foreground="{DynamicResource FgBrush}" BorderBrush="#40888888"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Sección 3: Detalle de Productos -->
                                    <TextBlock Grid.Row="6" Text="Detalle de Productos" FontWeight="SemiBold" FontSize="16" Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,10"/>
                                    <Grid Grid.Row="7" Margin="0,0,0,10">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="0.8*"/>
                                            <ColumnDefinition Width="3*"/>
                                            <ColumnDefinition Width="0.8*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="1.2*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Código" FontWeight="SemiBold" Margin="0,0,5,5"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Descripción" FontWeight="SemiBold" Margin="5,0,5,5"/>
                                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Cant." FontWeight="SemiBold" Margin="5,0,5,5"/>
                                        <TextBlock Grid.Row="0" Grid.Column="3" Text="Precio Unit." FontWeight="SemiBold" Margin="5,0,5,5"/>
                                        <TextBlock Grid.Row="0" Grid.Column="4" Text="IGV" FontWeight="SemiBold" Margin="5,0,0,5"/>

                                        <TextBox x:Name="BoletaDetalleCodigoTextBox" Grid.Row="1" Grid.Column="0" Text="" Height="35" Padding="5" VerticalContentAlignment="Center" Background="{DynamicResource BgBrush}" Foreground="{DynamicResource FgBrush}" BorderBrush="#40888888" Margin="0,0,5,20"/>
                                        <TextBox x:Name="BoletaDetalleDescripcionTextBox" Grid.Row="1" Grid.Column="1" Text="Grabadora de Video" Height="35" Padding="5" VerticalContentAlignment="Center" Background="{DynamicResource BgBrush}" Foreground="{DynamicResource FgBrush}" BorderBrush="#40888888" Margin="5,0,5,20"/>
                                        <TextBox x:Name="BoletaDetalleCantidadTextBox" Grid.Row="1" Grid.Column="2" Text="1" Height="35" Padding="5" VerticalContentAlignment="Center" Background="{DynamicResource BgBrush}" Foreground="{DynamicResource FgBrush}" BorderBrush="#40888888" Margin="5,0,5,20"/>
                                        <TextBox x:Name="BoletaDetallePrecioUnitTextBox" Grid.Row="1" Grid.Column="3" Text="254.24" Height="35" Padding="5" VerticalContentAlignment="Center" Background="{DynamicResource BgBrush}" Foreground="{DynamicResource FgBrush}" BorderBrush="#40888888" Margin="5,0,5,20"/>
                                        <TextBox x:Name="BoletaDetalleIgvTextBox" Grid.Row="1" Grid.Column="4" Text="45.76" Height="35" Padding="5" VerticalContentAlignment="Center" Background="{DynamicResource BgBrush}" Foreground="{DynamicResource FgBrush}" BorderBrush="#40888888" Margin="5,0,0,20"/>
                                    </Grid>

                                    <!-- Sección 4: Totales -->
                                    <Grid Grid.Row="8" Margin="0,80,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" MinWidth="300" />
                                        </Grid.ColumnDefinitions>
                                        
                                        <StackPanel Grid.Column="1" HorizontalAlignment="Right" MinWidth="250" Margin="0,0,20,0">
                                            <Grid Margin="0,5">
                                                <TextBlock Text="IGV (Incluido):" HorizontalAlignment="Left" FontSize="14"/>
                                                <TextBlock Text="S/ 45.76" HorizontalAlignment="Right" FontWeight="SemiBold" FontSize="14"/>
                                            </Grid>
                                            <Border BorderBrush="#40888888" BorderThickness="0,1,0,0" Margin="0,10"/>
                                            <Grid Margin="0,5">
                                                <TextBlock Text="Total Venta:" HorizontalAlignment="Left" FontSize="18" FontWeight="Bold"/>
                                                <TextBlock Text="S/ 300.00" HorizontalAlignment="Right" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"/>
                                            </Grid>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Sección 5: Botón de Guardar -->
                                    <StackPanel Grid.Row="9" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,60,0,20">
                                        <Button Content="Limpiar" MinWidth="150" Height="45" Background="Transparent" Foreground="{DynamicResource FgBrush}" BorderBrush="#40888888" BorderThickness="1" Margin="0,0,20,0" FontSize="14" Padding="20,0" Click="LimpiarBoleta_Click"/>
                                        <Button Content="Generar y Enviar a SUNAT" MinWidth="250" Height="45" Background="{DynamicResource AccentBrush}" Foreground="White" FontWeight="SemiBold" FontSize="14" Padding="20,0" Click="EmitirBoleta_Click"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Grid>

            <!-- View: Historial -->
            <Grid x:Name="HistorialView" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Historial de Comprobantes" FontSize="28" FontWeight="SemiBold" Margin="0,10,0,20" />

                <!-- Filtros -->
                <Border Grid.Row="1" Background="{DynamicResource CardBgBrush}" CornerRadius="10" Padding="15" Margin="0,0,0,20">
                    <StackPanel Orientation="Horizontal">
                        <StackPanel Margin="0,0,20,0">
                            <TextBlock Text="Desde" Opacity="0.7" Margin="0,0,0,5"/>
                            <DatePicker x:Name="HistorialDesdePicker" Width="150" Height="30" />
                        </StackPanel>
                        <StackPanel Margin="0,0,20,0">
                            <TextBlock Text="Hasta" Opacity="0.7" Margin="0,0,0,5"/>
                            <DatePicker x:Name="HistorialHastaPicker" Width="150" Height="30" />
                        </StackPanel>
                        <Button Content="Buscar" Width="100" Height="35" Margin="0,15,0,0" Background="{DynamicResource AccentBrush}" Foreground="White" Click="BuscarHistorial_Click" />
                    </StackPanel>
                </Border>

                <!-- Tabla -->
                <Border Grid.Row="2" Background="{DynamicResource CardBgBrush}" CornerRadius="10" Padding="10">
                    <DataGrid x:Name="HistorialDataGrid" ItemsSource="{Binding Comprobantes}" AutoGenerateColumns="False" IsReadOnly="True" Background="Transparent" BorderThickness="0" SelectionMode="Single" RowHeight="40" VerticalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Fecha" Binding="{Binding FechaEmision, StringFormat=\{0:dd/MM/yyyy HH:mm\}}" Width="150"/>
                            <DataGridTextColumn Header="Tipo" Binding="{Binding TipoDoc}" Width="60"/>
                            <DataGridTextColumn Header="Serie-Correlativo" Binding="{Binding SerieCorrelativo}" Width="120"/>
                            <DataGridTextColumn Header="Cliente" Binding="{Binding NombreCliente}" Width="*"/>
                            <DataGridTextColumn Header="Total" Binding="{Binding Total, StringFormat=S/ \{0:N2\}}" Width="100"/>
                            <DataGridTemplateColumn Header="Acciones" Width="180">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="PDF" Margin="5,0" Padding="10,2" Background="#E11D48" Foreground="White" Click="DescargarPdf_Click" Tag="{Binding PdfPath}"/>
                                            <Button Content="XML" Margin="5,0" Padding="10,2" Background="{DynamicResource AccentBrush}" Foreground="White" Click="DescargarXml_Click" Tag="{Binding XmlPath}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
