<Window x:Class="GinGo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GinGo"
        mc:Ignorable="d"
        Title="GinGo - Iniciar sesión"
        Height="540"
        Width="980"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FFFFFFFF" Offset="0" />
                <GradientStop Color="#FFEAF0FF" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="420" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" CornerRadius="16" Margin="24">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FF1F6FEB" Offset="0" />
                    <GradientStop Color="#FF6F42C1" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <StackPanel Margin="32" VerticalAlignment="Center">
                    <TextBlock Text="GinGo" Foreground="White" FontSize="40" FontWeight="SemiBold" />
                    <TextBlock Text="Sistema de facturación" Foreground="#E8FFFFFF" FontSize="16" Margin="0,6,0,0" />
                    <TextBlock Text="Accede para continuar" Foreground="#D9FFFFFF" FontSize="14" Margin="0,28,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Border Width="420"
                    Background="White"
                    CornerRadius="16"
                    Padding="28"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="18" ShadowDepth="0" Opacity="0.16" />
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Iniciar sesión" FontSize="22" FontWeight="SemiBold" Foreground="#FF0F172A" />

                    <TextBlock Grid.Row="1" Text="Usuario o correo" Foreground="#FF475569" Margin="0,16,0,6" />
                    <TextBox Grid.Row="1"
                             x:Name="LoginUserOrEmailTextBox"
                             Height="38"
                             Padding="12,8"
                             Margin="0,42,0,0"
                             Background="#FFF8FAFF"
                             BorderBrush="#FFE2E8F0"
                             BorderThickness="1"
                             VerticalContentAlignment="Center" />

                    <TextBlock Grid.Row="2" Text="Contraseña" Foreground="#FF475569" Margin="0,12,0,6" />
                    <PasswordBox Grid.Row="2"
                                 x:Name="LoginPasswordBox"
                                 Height="38"
                                 Padding="12,8"
                                 Margin="0,38,0,0"
                                 Background="#FFF8FAFF"
                                 BorderBrush="#FFE2E8F0"
                                 BorderThickness="1" />

                    <Button Grid.Row="3"
                            x:Name="LoginButton"
                            Content="Entrar"
                            Height="40"
                            Margin="0,18,0,0"
                            Background="#FF1F6FEB"
                            Foreground="White"
                            BorderThickness="0"
                            FontWeight="SemiBold"
                            Click="LoginButton_Click" />

                    <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,18,0,0">
                        <TextBlock Text="¿No tienes cuenta?" Foreground="#FF64748B" />
                        <TextBlock Margin="6,0,0,0">
                            <Hyperlink Foreground="#FF1F6FEB" Click="CreateAccountLink_Click">Crear cuenta</Hyperlink>
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>






