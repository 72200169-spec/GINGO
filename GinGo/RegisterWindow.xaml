<Window x:Class="GinGo.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GinGo"
        mc:Ignorable="d"
        Title="GinGo - Registrar usuario"
        Height="640"
        Width="980"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FFFFFFFF" Offset="0" />
                <GradientStop Color="#FFEAF0FF" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="420" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" CornerRadius="16" Margin="24">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FF0EA5E9" Offset="0" />
                    <GradientStop Color="#FF1F6FEB" Offset="0.55" />
                    <GradientStop Color="#FF6F42C1" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel Margin="32" VerticalAlignment="Center">
                <TextBlock Text="Crear cuenta" Foreground="White" FontSize="34" FontWeight="SemiBold" />
                <TextBlock Text="Acceso al sistema de facturación" Foreground="#E8FFFFFF" FontSize="14" Margin="0,10,0,0" />
                <TextBlock Text="Tu contraseña debe ser fuerte para registrarte." Foreground="#D9FFFFFF" FontSize="14" Margin="0,28,0,0" TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Border Grid.Column="1"
                Width="520"
                Background="White"
                CornerRadius="16"
                Padding="28"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect BlurRadius="18" ShadowDepth="0" Opacity="0.16" />
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Text="Registrar usuario" FontSize="22" FontWeight="SemiBold" Foreground="#FF0F172A" />

                <Grid Grid.Row="1" Margin="0,18,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Nombre de usuario" Foreground="#FF475569" Margin="0,0,0,6" />
                        <TextBox x:Name="UsernameTextBox"
                                 Height="38"
                                 Padding="12,8"
                                 Background="#FFF8FAFF"
                                 BorderBrush="#FFE2E8F0"
                                 BorderThickness="1"
                                 VerticalContentAlignment="Center"
                                 TextChanged="AnyField_Changed" />
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Correo electrónico" Foreground="#FF475569" Margin="0,0,0,6" />
                        <TextBox x:Name="EmailTextBox"
                                 Height="38"
                                 Padding="12,8"
                                 Background="#FFF8FAFF"
                                 BorderBrush="#FFE2E8F0"
                                 BorderThickness="1"
                                 VerticalContentAlignment="Center"
                                 TextChanged="AnyField_Changed" />
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Row="2" Margin="0,12,0,0">
                    <TextBlock Text="Número de teléfono (opcional)" Foreground="#FF475569" Margin="0,0,0,6" />
                    <TextBox x:Name="PhoneTextBox"
                             Height="38"
                             Padding="12,8"
                             Background="#FFF8FAFF"
                             BorderBrush="#FFE2E8F0"
                             BorderThickness="1"
                             VerticalContentAlignment="Center"
                             TextChanged="AnyField_Changed" />
                </StackPanel>

                <Grid Grid.Row="3" Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Contraseña" Foreground="#FF475569" Margin="0,0,0,6" />
                        <PasswordBox x:Name="PasswordBox"
                                     Height="38"
                                     Padding="12,8"
                                     Background="#FFF8FAFF"
                                     BorderBrush="#FFE2E8F0"
                                     BorderThickness="1"
                                     PasswordChanged="PasswordBoxes_PasswordChanged" />
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Repetir contraseña" Foreground="#FF475569" Margin="0,0,0,6" />
                        <PasswordBox x:Name="RepeatPasswordBox"
                                     Height="38"
                                     Padding="12,8"
                                     Background="#FFF8FAFF"
                                     BorderBrush="#FFE2E8F0"
                                     BorderThickness="1"
                                     PasswordChanged="PasswordBoxes_PasswordChanged" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="4" Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Seguridad:" Foreground="#FF475569" VerticalAlignment="Center" />

                    <Border Grid.Column="1"
                            Margin="10,0,10,0"
                            Height="10"
                            CornerRadius="5"
                            Background="#FFF1F5F9"
                            BorderBrush="#FFE2E8F0"
                            BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Rectangle Grid.Column="0" x:Name="StrengthRect1" RadiusX="5" RadiusY="5" Fill="#FFE2E8F0" Margin="1,1,0,1" />
                            <Rectangle Grid.Column="1" x:Name="StrengthRect2" RadiusX="0" RadiusY="0" Fill="#FFE2E8F0" Margin="0,1,0,1" />
                            <Rectangle Grid.Column="2" x:Name="StrengthRect3" RadiusX="5" RadiusY="5" Fill="#FFE2E8F0" Margin="0,1,1,1" />
                        </Grid>
                    </Border>

                    <TextBlock Grid.Column="2" x:Name="StrengthLabel" Text="—" Foreground="#FF64748B" VerticalAlignment="Center" />
                </Grid>

                <TextBlock Grid.Row="5"
                           Text="Requisitos: mínimo 8 caracteres, letras, números y un símbolo."
                           Foreground="#FF64748B"
                           Margin="0,10,0,0"
                           TextWrapping="Wrap" />

                <StackPanel Grid.Row="6" Margin="0,18,0,0">
                    <Button x:Name="RegisterButton"
                            Content="Registrar"
                            Height="40"
                            Background="#FF16A34A"
                            Foreground="White"
                            BorderThickness="0"
                            FontWeight="SemiBold"
                            IsEnabled="False"
                            Click="RegisterButton_Click" />

                    <Button Content="Volver"
                            Height="38"
                            Margin="0,10,0,0"
                            Background="Transparent"
                            BorderBrush="#FFE2E8F0"
                            BorderThickness="1"
                            Foreground="#FF0F172A"
                            Click="BackButton_Click" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
