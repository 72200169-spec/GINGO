<Window x:Class="GinGo.SunatLoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GinGo"
        mc:Ignorable="d"
        Title="GinGo - Validar SUNAT" Height="580" Width="450"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{DynamicResource BgBrush}"
        Foreground="{DynamicResource FgBrush}">
    <Border Background="{DynamicResource CardBgBrush}" CornerRadius="16" Margin="24" Padding="32">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18" ShadowDepth="0" Opacity="0.16" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Text="Validación SUNAT" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource FgBrush}" HorizontalAlignment="Center" />
            <TextBlock Grid.Row="1" Text="Ingresa tus credenciales SOL para facturar" FontSize="14" Foreground="{DynamicResource FgBrush}" Opacity="0.7" HorizontalAlignment="Center" Margin="0,5,0,10" TextWrapping="Wrap" TextAlignment="Center" />
            
            <TextBlock Grid.Row="2" Text="Datos de prueba: RUC: 10452369871 | Usuario: ADMINSOL | Pass: Sol123!" FontSize="11" Foreground="#3B82F6" HorizontalAlignment="Center" Margin="0,0,0,15" />

            <TextBlock Grid.Row="3" Text="RUC" Foreground="{DynamicResource FgBrush}" Opacity="0.8" Margin="0,10,0,6" />
            <TextBox Grid.Row="4"
                     x:Name="SunatRucTextBox"
                     Height="38"
                     Padding="12,8"
                     Background="{DynamicResource BgBrush}"
                     Foreground="{DynamicResource FgBrush}"
                     BorderBrush="#40888888"
                     BorderThickness="1"
                     VerticalContentAlignment="Center" />

            <TextBlock Grid.Row="5" Text="Usuario SOL" Foreground="{DynamicResource FgBrush}" Opacity="0.8" Margin="0,12,0,6" />
            <TextBox Grid.Row="6"
                     x:Name="SunatUserTextBox"
                     Height="38"
                     Padding="12,8"
                     Background="{DynamicResource BgBrush}"
                     Foreground="{DynamicResource FgBrush}"
                     BorderBrush="#40888888"
                     BorderThickness="1"
                     VerticalContentAlignment="Center" />

            <TextBlock Grid.Row="7" Text="Contraseña SOL" Foreground="{DynamicResource FgBrush}" Opacity="0.8" Margin="0,12,0,6" />
            <PasswordBox Grid.Row="8"
                         x:Name="SunatPasswordBox"
                         Height="38"
                         Padding="12,8"
                         Background="{DynamicResource BgBrush}"
                         Foreground="{DynamicResource FgBrush}"
                         BorderBrush="#40888888"
                         BorderThickness="1" />

            <StackPanel Grid.Row="9" VerticalAlignment="Center" Margin="0,25,0,0">
                <Button Content="Validar e Ingresar" Height="40" Background="{DynamicResource AccentBrush}" Foreground="White" FontWeight="SemiBold" Click="ValidateSunat_Click" />
                <Button Content="Regresar al Login" Height="35" Background="Transparent" Foreground="{DynamicResource FgBrush}" Opacity="0.8" Margin="0,10,0,0" Click="BackToLogin_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>