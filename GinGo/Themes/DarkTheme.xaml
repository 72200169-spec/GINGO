<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="BgColor">#0B1220</Color>
    <Color x:Key="FgColor">#F8FAFC</Color>
    <Color x:Key="SidebarBgColor">#111827</Color>
    <Color x:Key="SidebarFgColor">#E5E7EB</Color>
    <Color x:Key="AccentColor">#60A5FA</Color>
    <Color x:Key="AccentHoverColor">#93C5FD</Color>
    <Color x:Key="CardBgColor">#172033</Color>
    <Color x:Key="InputBgColor">#1E293B</Color>
    <Color x:Key="InputBorderColor">#475569</Color>
    <Color x:Key="InputFocusColor">#60A5FA</Color>
    <Color x:Key="MutedFgColor">#94A3B8</Color>
    <Color x:Key="SecondaryButtonBgColor">#243041</Color>
    <Color x:Key="SecondaryButtonHoverColor">#334155</Color>
    <Color x:Key="ReadonlyBgColor">#273449</Color>

    <SolidColorBrush x:Key="BgBrush" Color="{StaticResource BgColor}" />
    <SolidColorBrush x:Key="FgBrush" Color="{StaticResource FgColor}" />
    <SolidColorBrush x:Key="SidebarBgBrush" Color="{StaticResource SidebarBgColor}" />
    <SolidColorBrush x:Key="SidebarFgBrush" Color="{StaticResource SidebarFgColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}" />
    <SolidColorBrush x:Key="CardBgBrush" Color="{StaticResource CardBgColor}" />
    <SolidColorBrush x:Key="InputBgBrush" Color="{StaticResource InputBgColor}" />
    <SolidColorBrush x:Key="InputBorderBrush" Color="{StaticResource InputBorderColor}" />
    <SolidColorBrush x:Key="InputFocusBrush" Color="{StaticResource InputFocusColor}" />
    <SolidColorBrush x:Key="MutedFgBrush" Color="{StaticResource MutedFgColor}" />
    <SolidColorBrush x:Key="SecondaryButtonBgBrush" Color="{StaticResource SecondaryButtonBgColor}" />
    <SolidColorBrush x:Key="SecondaryButtonHoverBrush" Color="{StaticResource SecondaryButtonHoverColor}" />
    <SolidColorBrush x:Key="ReadonlyBgBrush" Color="{StaticResource ReadonlyBgColor}" />
</ResourceDictionary>
